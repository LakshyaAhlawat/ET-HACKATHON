# LLM providers
GROQ_API_KEY=
GEMINI_API_KEY=

# Neo4j AuraDB (free tier, cloud-hosted — no local container)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Overridden by docker-compose for the backend service; useful for running
# the backend outside Docker against the compose-managed Postgres/Qdrant.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/epc
QDRANT_URL=http://localhost:6333
